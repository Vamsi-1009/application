# Copy to .env and fill in real values. Never commit the real .env.
DATABASE_URL=postgres://user:CHANGE_ME@localhost:5432/tinylink
JWT_SIGNING_KEY=replace_with_a_random_32_plus_character_value
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
PORT=8000
CORS_ORIGIN=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:8000

# SMTP is optional for local dev - if unset, OTP codes are logged to the
# console instead of emailed (see src/lib/mailer.ts).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
